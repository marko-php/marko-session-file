{
    "name": "marko/session-file",
    "description": "File-based session driver for Marko Framework",
    "type": "marko-module",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "marko/session": "self.version"
    },
    "require-dev": {
        "marko/testing": "self.version"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Session\\File\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Session\\File\\Tests\\": "tests/"
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
